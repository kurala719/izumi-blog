---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type PostEntry = CollectionEntry<'posts'>;

export async function getStaticPaths() {
	const posts = (await getCollection('posts')) as PostEntry[];
	const visiblePosts = posts.filter((post) => !post.data.draft);
	return visiblePosts.map((post) => ({
		params: { slug: post.id.replace(/\.md$/, '') },
		props: { post },
	}));
}

const { post } = Astro.props as { post: PostEntry };
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
---

<Layout title={`${post.data.title} · Izumi blog`} description={post.data.excerpt}>
	<article class="post container">
		<header>
			<p class="meta">
				<span>{post.data.category ?? '未分类'}</span>
				<span>·</span>
				<span>{post.data.date.toISOString().slice(0, 10)}</span>
				<span>·</span>
				<span>{post.data.readingTime ?? '5 min'}</span>
			</p>
			<h1>{post.data.title}</h1>
			<p class="excerpt">{post.data.excerpt}</p>
			<div class="tags">
				{post.data.tags.map((tag: string) => (
					<a href={`${base}tags/${encodeURIComponent(tag)}`}>#{tag}</a>
				))}
			</div>
		</header>
		<section class="content">
			<Content />
		</section>
	</article>
</Layout>

<style>
	.post {
		padding: 64px 0 48px;
	}

	header {
		margin-bottom: 32px;
	}

	h1 {
		margin: 12px 0 10px;
		font-size: clamp(2rem, 4vw, 3rem);
	}

	.meta {
		color: var(--ink-soft);
		font-size: 0.9rem;
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		margin: 0;
	}

	.excerpt {
		color: var(--ink-soft);
		max-width: 720px;
	}

	.tags {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		margin-top: 14px;
	}

	.tags a {
		padding: 6px 12px;
		border-radius: 999px;
		border: 1px solid var(--line);
		color: var(--ink-soft);
		font-size: 0.85rem;
	}

	.content {
		display: grid;
		gap: 16px;
		font-size: 1rem;
	}

	.content :global(h2) {
		margin: 24px 0 8px;
		font-size: 1.4rem;
	}

	.content :global(ul) {
		padding-left: 18px;
		color: var(--ink-soft);
	}

	.content :global(p) {
		color: var(--ink-soft);
	}
</style>
