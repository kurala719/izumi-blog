---
import Layout from '../layouts/Layout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

type PostEntry = CollectionEntry<'posts'>;

const posts = (await getCollection('posts')) as PostEntry[];
const visiblePosts = posts.filter((post) => !post.data.draft);
const sortedPosts = visiblePosts.sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const latestPosts = sortedPosts.slice(0, 6);
const featured = sortedPosts[0];
const getSlug = (post: PostEntry) => post.id.replace(/\.md$/, '');
const base = import.meta.env.BASE_URL;
const tagCounts = sortedPosts.reduce((acc: Map<string, number>, post: PostEntry) => {
	post.data.tags.forEach((tag: string) => {
		acc.set(tag, (acc.get(tag) ?? 0) + 1);
	});
	return acc;
}, new Map<string, number>());
const tags = (Array.from(tagCounts.entries()) as [string, number][]) 
	.sort((a, b) => b[1] - a[1]);
---

<Layout title="Izumi blog · 极简黑" description="Izumi blog：技术、热点与日常的极简黑色调博客。">
	<section class="hero container">
		<p class="eyebrow">Minimal / Dark / Focus</p>
		<h1>只保留观点与证据。</h1>
		<p class="hero-sub">
			记录技术话题、热点评论与日常观察。更新基于真实文章数据自动生成。
		</p>
		<div class="hero-actions">
			<a class="btn primary" href="#latest">最新文章</a>
			<a class="btn ghost" href={`${base}tags`}>浏览标签</a>
		</div>
	</section>

	<section class="section container">
		<div class="featured">
			<div>
				<p class="label">置顶</p>
				{featured ? (
					<h2>{featured.data.title}</h2>
				) : (
					<h2>还没有发布文章</h2>
				)}
				<p>{featured?.data.excerpt ?? '从 content/posts 添加第一篇文章。'}</p>
			</div>
			{featured && (
				<a class="link" href={`${base}posts/${getSlug(featured)}`}>阅读 →</a>
			)}
		</div>
	</section>

	<section id="latest" class="section container">
		<div class="section-head">
			<h3>最新文章</h3>
			<span>{latestPosts.length} 篇</span>
		</div>
		<div class="grid">
			{latestPosts.map((post: PostEntry) => (
				<PostCard post={post} />
			))}
		</div>
	</section>

	<section class="section container">
		<div class="section-head">
			<h3>标签</h3>
			<span>{tags.length} 个</span>
		</div>
		<div class="tag-grid">
			{tags.map(([tag, count]: [string, number]) => (
				<a class="tag" href={`${base}tags/${encodeURIComponent(tag)}`}>
					<span>#{tag}</span>
					<span class="tag-count">{count}</span>
				</a>
			))}
		</div>
	</section>
</Layout>

<style>
	.hero {
		padding: 72px 0 36px;
		display: grid;
		gap: 18px;
	}

	.eyebrow {
		font-family: var(--mono);
		letter-spacing: 0.4em;
		text-transform: uppercase;
		font-size: 0.7rem;
		color: var(--ink-soft);
		margin: 0;
	}

	.hero h1 {
		font-size: clamp(2.4rem, 4vw, 3.4rem);
		margin: 0;
	}

	.hero-sub {
		color: var(--ink-soft);
		max-width: 560px;
		margin: 0;
	}

	.hero-actions {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		margin-top: 6px;
	}

	.btn {
		padding: 10px 18px;
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 600;
		border: 1px solid transparent;
		transition: transform 0.2s ease, background 0.2s ease;
	}

	.btn.primary {
		background: var(--ink);
		color: var(--bg);
	}

	.btn.ghost {
		background: transparent;
		color: var(--ink);
		border-color: var(--line);
	}

	.btn:hover {
		transform: translateY(-2px);
	}

	.section {
		padding: 28px 0;
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		color: var(--ink-soft);
		margin-bottom: 16px;
		font-size: 0.9rem;
	}

	.section-head h3 {
		margin: 0;
		color: var(--ink);
		font-size: 1.2rem;
	}

	.featured {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 16px;
		padding: 22px;
		border-radius: var(--radius-md);
		background: var(--bg-card);
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
	}

	.featured h2 {
		margin: 8px 0 10px;
		font-size: 1.4rem;
	}

	.featured p {
		margin: 0;
		color: var(--ink-soft);
	}

	.label {
		margin: 0;
		font-size: 0.75rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--ink-soft);
	}

	.link {
		font-weight: 600;
		color: var(--accent);
	}

	.grid {
		display: grid;
		gap: 14px;
		grid-template-columns: repeat(2, minmax(0, 1fr));
	}

	.tag-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 12px;
	}

	.tag {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 12px 14px;
		border-radius: var(--radius-md);
		background: var(--bg-card);
		border: 1px solid var(--line);
		color: var(--ink);
	}

	.tag-count {
		color: var(--ink-soft);
		font-size: 0.85rem;
	}

	@media (max-width: 860px) {
		.grid {
			grid-template-columns: 1fr;
		}

		.featured {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
